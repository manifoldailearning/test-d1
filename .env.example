# Copy this file to `.env` in this same directory (next to `.env.example`).
# The app loads it via `load_dotenv()` from `src.hardened_support.paths.load_app_dotenv`.

# Required for supervisor routing and specialists (OpenAI API).
OPENAI_API_KEY=

# Optional: Azure OpenAI–compatible base URL.
# OPENAI_BASE_URL=

# Optional per-role model overrides (default is gpt-4o-mini for each).
# HARDEN_MODEL_SUPERVISOR=
# HARDEN_MODEL_GENERAL_AGENT=
# HARDEN_MODEL_ORDERS_AGENT=
# HARDEN_MODEL_BILLING_AGENT=
# HARDEN_MODEL_TECHNICAL_AGENT=
# HARDEN_MODEL_SYNTHESIS=

# Optional: set to 1 so the specialist prompt simulates a first-tool failure (teaching demo).
# SIMULATE_TOOL_FAILURE=0

# Structured JSON trace export (json.dump) after each graph run — deploy mount this dir (e.g. emptyDir).
# HARDEN_TRACE_DIR=/var/log/hardened_support/traces
# HARDEN_TRACE_EXPORT=1
# HARDEN_TRACE_JSON_PRETTY=0
